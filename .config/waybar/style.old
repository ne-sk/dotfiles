/* ===== GLOBAL ===== */
* {
  padding: 0;
  margin: 0;
  min-height: 0;
  border-radius: 0;
  border: none;
  text-shadow: none;
  transition: none;
  box-shadow: none;
  background-color: #282828;
  color: #d4be98;
}

window#waybar {
  font-family: JetBrainsMono Nerd Font Propo;
  font-size: 14px;
}

.modules-left {
  margin-left: 8px;
}

.modules-right {
  margin-right: 8px;
}

/* ===== COMMON PADDING ===== */
#window,
#bluetooth,
#pulseaudio,
#pulseaudio.muted,
#battery,
#battery.critical,
#battery.warning,
#network,
#power-profiles-daemon,
#clock {
  padding: 8px 8px;
}

/* ===== MODULES ===== */
#workspaces {
  background-color: #282828;
}

#workspaces button {
  margin: 0 6px;
}

#workspaces button.active,
#workspaces button.active * {
  /* border-bottom: 2px solid #ea6962; */
  color: #ea6962;
}

#language {
  margin: 0 8px;
}
